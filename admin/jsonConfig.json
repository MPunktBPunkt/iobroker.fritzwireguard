{
  "type": "tabs",
  "items": {
    "connection": {
      "type": "panel",
      "label": "Verbindung",
      "items": {
        "fritzHost": {
          "type": "text",
          "label": "FritzBox IP (im VPN-Netz)",
          "default": "192.168.178.1",
          "sm": 12,
          "md": 6
        },
        "fritzPort": {
          "type": "number",
          "label": "TR-064 Port",
          "default": 49000,
          "sm": 12,
          "md": 6
        },
        "fritzUser": {
          "type": "text",
          "label": "FritzBox Benutzername",
          "sm": 12,
          "md": 6
        },
        "fritzPass": {
          "type": "password",
          "label": "FritzBox Passwort",
          "sm": 12,
          "md": 6
        },
        "webPort": {
          "type": "number",
          "label": "Web-UI Port",
          "default": 8094,
          "sm": 12,
          "md": 6
        },
        "pollInterval": {
          "type": "number",
          "label": "Poll-Intervall (Sekunden, min. 30)",
          "default": 60,
          "sm": 12,
          "md": 6
        }
      }
    },
    "wireguard": {
      "type": "panel",
      "label": "WireGuard",
      "items": {
        "wgConfig": {
          "type": "text",
          "label": "WireGuard Config (.conf Inhalt)",
          "sm": 12,
          "help": "Vollstaendigen Inhalt der WireGuard .conf-Datei einfuegen. DNS-Zeilen und 0.0.0.0/0 werden automatisch entfernt."
        },
        "autoConnect": {
          "type": "checkbox",
          "label": "Beim Start automatisch verbinden",
          "default": true,
          "sm": 12
        },
        "autoReconnect": {
          "type": "checkbox",
          "label": "Bei Verbindungsabbruch neu verbinden",
          "default": true,
          "sm": 12
        },
        "wgDisconnectOnStop": {
          "type": "checkbox",
          "label": "WireGuard beim Adapter-Stopp trennen",
          "default": true,
          "sm": 12
        }
      }
    },
    "tunnels": {
      "type": "panel",
      "label": "Port-Tunnel",
      "items": {
        "tunnels": {
          "type": "table",
          "label": "TCP Port-Weiterleitungen (127.0.0.1:lokal -> Remote-IP:Port ueber VPN)",
          "sm": 12,
          "items": {
            "name": {
              "type": "text",
              "label": "Name",
              "width": "22%"
            },
            "localPort": {
              "type": "number",
              "label": "Lokaler Port",
              "width": "15%"
            },
            "remoteHost": {
              "type": "text",
              "label": "Ziel-IP",
              "width": "28%"
            },
            "remotePort": {
              "type": "number",
              "label": "Ziel-Port",
              "width": "15%"
            },
            "enabled": {
              "type": "checkbox",
              "label": "Aktiv",
              "default": true,
              "width": "10%"
            }
          }
        }
      }
    },
    "advanced": {
      "type": "panel",
      "label": "Erweitert",
      "items": {
        "logBuffer": {
          "type": "number",
          "label": "Log-Puffer (max. Eintraege)",
          "default": 500,
          "sm": 12,
          "md": 6
        }
      }
    }
  }
}